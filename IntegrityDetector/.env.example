# Copy to .env and adjust as needed. All optional — sane defaults exist in src/config.py.

# Require an NVIDIA GPU for training/inference (1 = strict, 0 = allow CPU fallback)
REQUIRE_CUDA=1

# Database (default: local SQLite). For PostgreSQL:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/plagiarism
# DATABASE_URL=sqlite:///app.db

# Flask
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Keep HuggingFace fully offline after the first model download (1 = offline)
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1
